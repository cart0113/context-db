#!/usr/bin/env bash
#
# pre-commit — Rebuild _toc.md files only if source files changed.
#
# Install:
#   cp hooks/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit

set -eo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
BUILD_TOC="${REPO_ROOT}/bin/build_toc.sh"

[ -x "$BUILD_TOC" ] || exit 0

# Target the project's context directory. Most projects use CONTEXT/ —
# change this path if your context tree lives elsewhere or if you have
# multiple trees to build.
cd "$REPO_ROOT"
"$BUILD_TOC" CONTEXT/

# Stage any updated _toc.md files
while IFS= read -r -d '' toc; do
    git add "$toc" 2>/dev/null || true
done < <(find . -name "*_toc.md" -not -path "*/.git/*" -print0)
